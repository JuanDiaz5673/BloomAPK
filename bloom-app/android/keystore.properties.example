# ─── Release signing config (Phase 5) ──────────────────────────────
#
# Copy this file to `keystore.properties` (same directory, no `.example`)
# and fill in the four values. That file is gitignored — it MUST NOT be
# committed. Lose the keystore → lose the ability to ship updates on
# Play Store. Back it up securely (password manager + off-machine copy).
#
# Generate the keystore once:
#
#   cd C:/Projects/BloomAPK
#   keytool -genkey -v -keystore bloom-release.keystore \
#     -alias bloom -keyalg RSA -keysize 2048 -validity 10000
#
# (keytool comes with the bundled JDK after `source env.sh`.)
#
# Then copy this file to keystore.properties and fill in:

# Absolute or relative path from bloom-app/android/ to the .keystore file.
# If you put the keystore at the repo root, the relative path is:
storeFile=../../bloom-release.keystore

storePassword=YOUR_STORE_PASSWORD_HERE
keyAlias=bloom
keyPassword=YOUR_KEY_PASSWORD_HERE

# ─── After filling this in, you can build a signed release: ─────────
#
#   cd bloom-app/android
#   ./gradlew bundleRelease        # produces app/build/outputs/bundle/release/app-release.aab
#   ./gradlew assembleRelease      # produces app/build/outputs/apk/release/app-release.apk
#
# Upload the .aab to Play Console Internal Testing.
