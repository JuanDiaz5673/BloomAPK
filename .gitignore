# Node / Capacitor
node_modules/
.pnpm-store/

# Toolchain (self-contained but ~2 GB — git-LFS not worth it)
tools/

# Android build artifacts
bloom-app/android/app/build/
bloom-app/android/build/
bloom-app/android/.gradle/
bloom-app/android/captures/
bloom-app/android/.idea/
bloom-app/android/local.properties
*.iml

# Capacitor generated
bloom-app/android/app/src/main/assets/public/
bloom-app/android/app/src/main/assets/capacitor.config.json
bloom-app/android/app/src/main/assets/capacitor.plugins.json

# Generated icon assets (regenerated by @capacitor/assets)
bloom-app/android/app/src/main/res/mipmap-*/ic_launcher*.png
bloom-app/android/app/src/main/res/mipmap-*/ic_launcher*.webp

# Dist — keep the sample APK committed so users can grab a release
# without building, but not the full build/ tree. Remove the next
# line to stop committing APKs entirely.
# dist/*.apk

# Fuzz/screenshot artifacts from local QA runs — noisy in git, kept local
dist/fuzz/

# Claude Code local settings
.claude/

# Local signing configs — NEVER commit these
*.keystore
*.jks
keystore.properties

# IDE
.vscode/
.idea/

# macOS
.DS_Store

# Logs
*.log
npm-debug.log*
